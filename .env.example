# Diffract .env.example
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — only .env.example belongs in version control.
#
# Generator for random tokens: openssl rand -hex 32

# ---- VPS Access ----
VPS_HOST=
VPS_USER=
VPS_PASSWORD=

