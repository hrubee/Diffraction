{
  "name": "@diffraction/mattermost",
  "version": "2026.3.22",
  "description": "Diffraction Mattermost channel plugin",
  "type": "module",
  "dependencies": {
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "diffraction": "workspace:*"
  },
  "peerDependencies": {
    "diffraction": ">=2026.3.22"
  },
  "peerDependenciesMeta": {
    "diffraction": {
      "optional": true
    }
  },
  "diffraction": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "mattermost",
      "label": "Mattermost",
      "selectionLabel": "Mattermost (plugin)",
      "docsPath": "/channels/mattermost",
      "docsLabel": "mattermost",
      "blurb": "self-hosted Slack-style chat; install the plugin to enable.",
      "order": 65
    },
    "install": {
      "npmSpec": "@diffraction/mattermost",
      "localPath": "extensions/mattermost",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.22"
    }
  }
}
