{
  "name": "@diffraction/synology-chat",
  "version": "2026.3.22",
  "description": "Synology Chat channel plugin for Diffraction",
  "type": "module",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "diffraction": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "synology-chat",
      "label": "Synology Chat",
      "selectionLabel": "Synology Chat (Webhook)",
      "docsPath": "/channels/synology-chat",
      "docsLabel": "synology-chat",
      "blurb": "Connect your Synology NAS Chat to Diffraction with full agent capabilities.",
      "order": 90
    },
    "install": {
      "npmSpec": "@diffraction/synology-chat",
      "localPath": "extensions/synology-chat",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.22"
    }
  }
}
