{
  "name": "@diffraction/discord",
  "version": "2026.3.22",
  "description": "Diffraction Discord channel plugin",
  "type": "module",
  "dependencies": {
    "@buape/carbon": "0.0.0-beta-20260317045421",
    "@discordjs/voice": "^0.19.2",
    "discord-api-types": "^0.38.42",
    "https-proxy-agent": "^8.0.0",
    "opusscript": "^0.1.1"
  },
  "devDependencies": {
    "diffraction": "workspace:*"
  },
  "peerDependencies": {
    "diffraction": ">=2026.3.22"
  },
  "peerDependenciesMeta": {
    "diffraction": {
      "optional": true
    }
  },
  "diffraction": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "discord",
      "label": "Discord",
      "selectionLabel": "Discord (Bot API)",
      "detailLabel": "Discord Bot",
      "docsPath": "/channels/discord",
      "docsLabel": "discord",
      "blurb": "very well supported right now.",
      "systemImage": "bubble.left.and.bubble.right"
    },
    "install": {
      "npmSpec": "@diffraction/discord",
      "localPath": "extensions/discord",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.22"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    },
    "release": {
      "publishToNpm": true
    }
  }
}
